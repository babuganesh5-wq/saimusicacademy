{
  "manifest_version": 3,
  "name": "Gemini Telemetry & Observability Toolkit",
  "version": "1.0.0",
  "description": "Real-time token counting, request tracing, and cost estimation for Google Gemini API and AI Studio calls.",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://aistudio.google.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "devtools_page": "devtools.html",
  "content_scripts": [
    {
      "matches": [
        "https://aistudio.google.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
